---
export interface Props {
  title: string;
  description: string;
  ctaHref: string;
  ctaLabel?: string;
  badge?: string;
  price?: string;
  trackingLabel?: string;
}

const { title, description, ctaHref, ctaLabel = 'Learn More', badge, price, trackingLabel } = Astro.props;
const isExternal = ctaHref.startsWith('http');
---

<div class="program-card">
  <div class="program-card-header">
    <div class="program-card-title">{title}</div>
    {badge && <span class="program-badge">{badge}</span>}
  </div>
  <div class="program-card-desc">{description}</div>
  <div class="program-card-footer">
    {price && <div class="program-price">{price}</div>}
    <a
      href={ctaHref}
      class="program-cta"
      {...isExternal ? { target: '_blank' } : {}}
      {...trackingLabel ? { 'data-track': trackingLabel } : {}}
    >
      {ctaLabel} →
    </a>
  </div>
</div>

{trackingLabel && (
  <script define:vars={{ trackingLabel }}>
    document.querySelector(`[data-track="${trackingLabel}"]`)
      ?.addEventListener('click', () => {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'click', { event_category: 'program', event_label: trackingLabel });
        }
      });
  </script>
)}

<style>
  .program-card {
    background: var(--card-bg);
    border: 1px solid var(--accent-dim);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 10px;
    transition: all 0.25s ease;
  }

  .program-card:hover {
    border-color: var(--accent-border);
    background: var(--card-hover);
  }

  .program-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .program-card-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 2px;
    color: var(--white);
  }

  .program-badge {
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--accent-dim);
    border-radius: 4px;
    padding: 3px 8px;
    font-weight: 600;
  }

  .program-card-desc {
    font-size: 12px;
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .program-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .program-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 1px;
    color: var(--accent);
  }

  .program-cta {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .program-cta:hover {
    opacity: 0.7;
  }
</style>
