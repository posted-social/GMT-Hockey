---
export interface Stat {
  value: string;
  label: string;
}

export interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="stat-bar">
  {stats.map((stat, i) => (
    <>
      <div class="stat-item">
        <div class="stat-value">{stat.value}</div>
        <div class="stat-label">{stat.label}</div>
      </div>
      {i < stats.length - 1 && <div class="stat-divider" />}
    </>
  ))}
</div>

<style>
  .stat-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 20px 0;
  }

  .stat-item {
    flex: 1;
    text-align: center;
  }

  .stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gray);
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(219,207,189,0.1);
    flex-shrink: 0;
  }
</style>
